def build_audio_prompt(poi_dir: Path) -> str:
    es = read_text(poi_dir / "ESPAÑOL" / "texto.md").strip()
    en = read_text(poi_dir / "INGLES" / "texto.md").strip()
    pt = read_text(poi_dir / "PORTUGUES" / "texto.md").strip()

    missing = []
    if len(es) < 100:
        missing.append("Texto ES")
    if len(en) < 100:
        missing.append("Texto EN")
    if len(pt) < 100:
        missing.append("Texto PT")

    if missing:
        raise ValueError(
            "Falta contenido antes de generar los guiones: " + ", ".join(missing)
        )

    return f"""Generá los tres guiones de audio definitivos de este POI de UBIGUIA.

{PROMPT_MASTER_AUDIO}

POI
----------------
{poi_name(poi_dir)}

TEXTO ESPAÑOL DEFINITIVO
