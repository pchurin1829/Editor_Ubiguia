"""


def extract_available_sections(response_text: str) -> dict[str, str]:
    result: dict[str, str] = {}
    clean_response = _repair_mojibake(response_text)

    for key, (start, end) in MARKERS.items():
        pattern = re.escape(start) + r"\s*(.*?)\s*" + re.escape(end)
        match = re.search(pattern, clean_response, flags=re.DOTALL)

        if not match:
            continue

        content = match.group(1).strip()

        if len(content) < 40:
            raise ValueError(f"El bloque {key} está vacío o incompleto.")

        result[key] = content

    if not result:
        raise ValueError(
            "No se encontró ningún bloque válido. Copie la respuesta completa "
            "de ChatGPT, incluidos los marcadores <<<...>>>."
        )

    return result


def save_sections(poi_dir: Path, sections: dict[str, str]) -> list[str]:
    destinations = {
        "TEXT_ES": poi_dir / "ESPAÑOL" / "texto.md",
        "TEXT_EN": poi_dir / "INGLES" / "texto.md",
        "TEXT_PT": poi_dir / "PORTUGUES" / "texto.md",
        "AUDIO_ES": poi_dir / "ESPAÑOL" / "audio" / "guion_audio.md",
        "AUDIO_EN": poi_dir / "INGLES" / "audio" / "guion_audio.md",
        "AUDIO_PT": poi_dir / "PORTUGUES" / "audio" / "guion_audio.md",
    }

    labels = {
        "TEXT_ES": "Texto ES",
        "TEXT_EN": "Texto EN",
        "TEXT_PT": "Texto PT",
        "AUDIO_ES": "Guion de audio ES",
        "AUDIO_EN": "Guion de audio EN",
        "AUDIO_PT": "Guion de audio PT",
    }

    saved = []

    for key, content in sections.items():
        destination = destinations.get(key)
        if destination is None:
            continue

        write_text(destination, content)
        saved.append(labels[key])

    return saved


