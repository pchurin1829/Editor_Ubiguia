MARKERS = {
    "TEXT_ES": ("<<<TEXT_ES>>>", "<<<END_TEXT_ES>>>"),
    "TEXT_EN": ("<<<TEXT_EN>>>", "<<<END_TEXT_EN>>>"),
    "TEXT_PT": ("<<<TEXT_PT>>>", "<<<END_TEXT_PT>>>"),
    "AUDIO_ES": ("<<<AUDIO_ES>>>", "<<<END_AUDIO_ES>>>"),
    "AUDIO_EN": ("<<<AUDIO_EN>>>", "<<<END_AUDIO_EN>>>"),
    "AUDIO_PT": ("<<<AUDIO_PT>>>", "<<<END_AUDIO_PT>>>"),
}


def _repair_mojibake(text: str) -> str:
    """
    Repara texto UTF-8 interpretado erróneamente como Windows-1252/Latin-1.
    Ejemplos: 'PaÃ­s' -> 'País', 'C�mo' -> 'Cómo' cuando es recuperable.
    """
    if not text:
        return text

    candidates = [text]

    for source_encoding in ("cp1252", "latin-1"):
        try:
            candidates.append(text.encode(source_encoding).decode("utf-8"))
        except (UnicodeEncodeError, UnicodeDecodeError):
            pass

    bad_markers = ("Ã", "Â", "�", "â€", "ðŸ")

    def score(value: str) -> tuple[int, int]:
        bad = sum(value.count(marker) for marker in bad_markers)
        replacement = value.count("\ufffd")
        return bad + replacement * 5, len(value)

    return min(candidates, key=score)


def read_text(path: Path) -> str:
    if not path.exists() or not path.is_file():
        return ""

    raw = path.read_bytes()

    for encoding in ("utf-8-sig", "utf-8", "cp1252", "latin-1"):
        try:
            return _repair_mojibake(raw.decode(encoding))
        except UnicodeDecodeError:
            continue

    return _repair_mojibake(raw.decode("utf-8", errors="replace"))


def write_text(path: Path, content: str) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    clean = _repair_mojibake(content).strip() + "\n"
    path.write_text(clean, encoding="utf-8", newline="\n")


def poi_name(poi_dir: Path) -> str:
    return poi_dir.name.split("-", 1)[-1].strip()


